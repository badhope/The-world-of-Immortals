{
  "name": "the-world-of-immortals",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "author": "Immortal World Team",
  "description": "修仙世界模拟游戏 - 一个AI增强的修仙探索游戏",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build && electron-builder",
    "build:web": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "vite --mode electron",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "animate.css": "^4.1.1",
    "better-sqlite3": "^12.8.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "esbuild": "^0.27.4",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^3.2.5"
  },
  "build": {
    "appId": "com.immortalworld.game",
    "productName": "修仙世界",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "data/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
